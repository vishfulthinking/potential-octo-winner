generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Candidate {
  id               String   @id @default(cuid())
  oljId            String?  @unique
  title            String?
  description      String?
  skills           String?  // Stored as JSON string or comma-separated
  rateRaw          String?
  rate             Float?
  lastActive       String?
  profileUrl       String?
  otherDetailsJson String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  unlockedBy       UnlockedProfile[]
}

// NextAuth Required Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  credits       Int       @default(10) // Give 10 free credits for beta testing

  accounts      Account[]
  sessions      Session[]
  unlockedProfiles UnlockedProfile[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UnlockedProfile {
  id          String   @id @default(cuid())
  userId      String
  candidateId String
  unlockedAt  DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([userId, candidateId])
}
